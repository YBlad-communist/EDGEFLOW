# ─── Server ──────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── JWT ─────────────────────────────────────
JWT_SECRET=edgefloww_super_secret_change_in_prod
JWT_EXPIRES_IN=7d

# ─── MongoDB ─────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/edgefloww

# ─── DRM ─────────────────────────────────────
DRM_SECRET=edgefloww_drm_secret_change_in_prod_max32chars!!
DRM_TOKEN_TTL_MINUTES=15

# ─── CloudPayments ───────────────────────────
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=
PLATFORM_COMMISSION_PERCENT=5

# ─── Uploads ─────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500
