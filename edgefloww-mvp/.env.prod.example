# ─── Server ──────────────────────────────────
PORT=3001
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.com

# ─── JWT ─────────────────────────────────────
JWT_SECRET=your_strong_random_secret_here_min_32_chars
JWT_EXPIRES_IN=7d

# ─── MongoDB ─────────────────────────────────
MONGODB_URI=mongodb://mongo:27017/edgefloww

# ─── DRM ─────────────────────────────────────
DRM_SECRET=your_drm_secret_min_32_chars_here_!!
DRM_TOKEN_TTL_MINUTES=15

# ─── CloudPayments ───────────────────────────
CLOUDPAYMENTS_PUBLIC_ID=your_public_id_from_cloudpayments
CLOUDPAYMENTS_API_SECRET=your_api_secret_from_cloudpayments
PLATFORM_COMMISSION_PERCENT=5

# ─── Uploads ─────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500
